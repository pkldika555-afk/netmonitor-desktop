{
  "name": "netmonitor",
  "version": "1.0.0",
  "description": "Internal LAN Service Monitor",
  "author": "PKL Dika",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.netmonitor.app",
    "productName": "NetMonitor",
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime"
      },
      {
        "from": "www",
        "to": "www"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NetMonitor"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "asarUnpack": [
      "splash.html",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}
